{
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "jsx": "react-jsx",
    "noEmit": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "noUncheckedSideEffectImports": false,
    "paths": {
      "#/*": ["./src/*"]
    },
    "types": ["vitest/globals"]
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "out",
    "dist"
  ]
}

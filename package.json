{
  "name": "tistory-editor",
  "productName": "TistoryEditor",
  "version": "0.0.0-development",
  "description": "Editor for Tistory",
  "imports": {
    "#/*": "./src/*"
  },
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit",
    "preview": "electron-vite preview",
    "start": "electron-vite dev",
    "clean": "rimraf out dist app",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac --x64 --arm64",
    "dist:all": "npm run build && electron-builder --mac --win --linux",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joostory/tistory-editor.git"
  },
  "keywords": [
    "editor"
  ],
  "author": {
    "name": "Joo",
    "email": "joo@joostory.net",
    "url": "https://joostory.net"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/joostory/tistory-editor/issues"
  },
  "homepage": "https://tistory-editor.tistory.com",
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "rimraf": "^6.0.1",
    "sass": "^1.100.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.3",
    "vite-plugin-electron-renderer": "^0.14.7",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@tiptap/core": "^3.26.0",
    "@tiptap/extension-image": "^3.26.0",
    "@tiptap/pm": "^3.26.0",
    "@tiptap/react": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "axios": "^1.16.1",
    "cheerio": "^1.2.0",
    "dayjs": "^1.11.21",
    "electron-localshortcut": "^3.2.1",
    "electron-settings": "^4.0.4",
    "highlight.js": "^11.11.1",
    "immutability-helper": "^3.1.1",
    "isomorphic-fetch": "^3.0.0",
    "jotai": "^2.20.0",
    "oauth": "^0.10.2",
    "opengraph-fetcher": "^1.5.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "tumblr.js": "^5.0.1",
    "uuid": "^14.0.0"
  }
}

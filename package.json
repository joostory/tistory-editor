    "npm-run-all": "^4.1.5",
    "object-assign": "^4.1.1",
    "react-test-renderer": "^19.2.6",
    "regenerator-runtime": "^0.14.1",
    "resolve-url-loader": "^5.0.0",
    "sass": "^1.99.0",
    "sass-loader": "^17.0.0",
    "style-loader": "^4.0.0",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2"

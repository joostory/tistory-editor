{
  "name": "tistory-editor",
  "productName": "TistoryEditor",
  "version": "0.0.0-development",
  "description": "Editor for Tistory",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit",
    "preview": "electron-vite preview",
    "start": "electron-vite dev",
    "clean": "rimraf out dist app",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac --x64 --arm64",
    "dist:all": "npm run build && electron-builder --mac --win --linux",
    "test": "jest -u"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joostory/tistory-editor.git"
  },
  "keywords": [
    "editor"
  ],
  "author": {
    "name": "Joo",
    "email": "joo@joostory.net",
    "url": "https://joostory.net"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/joostory/tistory-editor/issues"
  },
  "homepage": "https://tistory-editor.tistory.com",
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "debug": "^4.4.3",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "jest": "^30.4.2",
    "object-assign": "^4.1.1",
    "react-test-renderer": "^19.2.6",
    "regenerator-runtime": "^0.14.1",
    "rimraf": "^6.0.1",
    "sass": "^1.99.0",
    "typescript": "^5.7.3",
    "vite": "^5.4.12",
    "vite-plugin-electron-renderer": "^0.14.7"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language-data": "^6.5.2",
    "@electron/remote": "^2.1.3",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@tiptap/core": "^3.23.5",
    "@tiptap/extension-image": "^3.23.5",
    "@tiptap/pm": "^3.23.5",
    "@tiptap/react": "^3.23.5",
    "@tiptap/starter-kit": "^3.23.5",
    "@uiw/react-codemirror": "^4.25.9",
    "autobind-decorator": "^2.4.0",
    "axios": "^1.16.1",
    "cheerio": "^1.2.0",
    "classnames": "^2.5.1",
    "core-js": "^3.49.0",
    "dayjs": "^1.11.20",
    "electron-google-analytics": "^1.0.2",
    "electron-localshortcut": "^3.2.1",
    "electron-settings": "^4.0.4",
    "form-data": "^4.0.5",
    "highlight.js": "^11.11.1",
    "immutability-helper": "^3.1.1",
    "isomorphic-fetch": "^3.0.0",
    "jotai": "^2.20.0",
    "marked": "^18.0.4",
    "node-fetch": "^3.3.2",
    "oauth": "^0.10.2",
    "opengraph-fetcher": "^1.5.3",
    "pinkie-promise": "^2.0.1",
    "prop-types": "^15.8.1",
    "querystring": "^0.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-dropzone": "^15.0.0",
    "react-router-dom": "^7.15.1",
    "tumblr.js": "^5.0.1",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "url": "^0.11.4",
    "uuid": "^14.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transformIgnorePatterns": [
      "/node_modules/(?!(marked)/)"
    ],
    "globals": {
      "navigator": {
        "userAgent": "Mozilla/5.0 (Macintosh; Intel Mac OS X 10_11_2) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/47.0.2526.106 Safari/537.36"
      }
    }
  }
}
